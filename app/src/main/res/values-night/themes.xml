<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.CuidaMedPill" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>

        <!-- Secundario -->
        <item name="colorSecondary">@color/md_third</item>

        <!-- Fondo oscuro con primary_dark -->
        <item name="android:colorBackground">@color/md_primary_dark</item>

        <!-- Surface ligeramente más claro que el fondo -->
        <item name="colorSurface">@color/md_surface_for_dark_mode</item>

        <!-- Textos (importante) -->
        <item name="colorOnPrimary">@color/md_blanco</item>
        <item name="colorOnBackground">@color/md_blanco</item>
        <item name="colorOnSurface">@color/md_blanco</item>

        <item name="titleColor">@color/md_background</item>
        <item name="titleSoftColor">@color/md_on_background_for_dark</item>
        <item name="titleNavColor">@color/md_surface</item>

        <!-- Error -->
        <item name="colorError">#CF6679</item>

    </style>

    <style name="WeekDayTextStyle">
        <item name="android:textColor">@color/md_blanco</item>
    </style>

    <style name="DayTextStyle">
        <item name="android:textColor">@color/md_blanco</item>
    </style>

    <style name="CalendarHeaderTextStyle">
        <item name="android:textColor">@color/md_blanco</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_surface</item>
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
    </style>

</resources>