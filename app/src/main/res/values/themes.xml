<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CuidaMedPill" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores base -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>
        <item name="colorSecondary">@color/md_third</item>

        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorSurface">@color/md_surface</item>

        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorOnSurface">@color/md_on_surface</item>

        <item name="titleColor">@color/md_primary_dark</item>
        <item name="titleSoftColor">@color/md_on_background</item>
        <item name="titleNavColor">@color/md_primary_dark</item>

        <item name="colorError">@color/md_error</item>

    </style>

    <style name="CustomDatePickerDialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="colorAccent">@color/md_primary</item>
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.MaterialComponents.Button.TextButton</item>
    </style>
    <style name="DatePickerButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/md_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.CuidaMedPill" parent="Base.Theme.CuidaMedPill" />

    <style name="ToolbarTitleBold" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WeekDayTextStyle">
        <item name="android:textColor">@color/md_primary_dark</item>
    </style>

    <style name="DayTextStyle">
        <item name="android:textColor">@color/md_primary_dark</item>
    </style>

    <style name="CalendarHeaderTextStyle">
        <item name="android:textColor">@color/md_primary_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_surface</item>
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
    </style>

</resources>