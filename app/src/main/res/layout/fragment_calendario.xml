<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/padding_mini"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBarCal"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="@string/text_title_meds"
        android:layout_marginTop="@dimen/margin_start"
        android:layout_marginStart="@dimen/margin_start"
        android:layout_marginEnd="@dimen/margin_end"
        app:titleTextAppearance="@style/ToolbarTitleBold"
        app:titleTextColor="@color/md_primary_dark"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="@dimen/padding_scroll">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvHintCalAsist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_hint_cal_asist"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:paddingBottom="@dimen/padding_bottom"
                android:layout_marginTop="@dimen/margin_top_element"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVistaSemanal"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:layout_marginTop="@dimen/margin_top_element"
                app:chipBackgroundColor="@color/md_surface"/>

            <!-- Calendario -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_top_element"
                app:cardCornerRadius="@dimen/card_cornerradious"
                app:cardElevation="@dimen/card_elevation">

                <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Fecha seleccionada -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvFechaSeleccionada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="@dimen/padding_bottom"
                android:layout_marginTop="@dimen/margin_top"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDiaEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay nada registrado para este día"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:visibility="gone"
                android:padding="@dimen/padding_general_light"/>

            <!-- RecyclerView dentro de NestedScrollView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMedicamentosDia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>