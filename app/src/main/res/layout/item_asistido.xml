<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAsistido"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/margin_vertical"
    android:layout_marginHorizontal="@dimen/margin_horizontal"
    app:cardElevation="@dimen/card_elevation"
    app:cardCornerRadius="@dimen/card_cornerradious"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_scroll">

        <!-- Fila principal: foto, nombre y botón supervisar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgFotoAsistido"
                android:layout_width="@dimen/size_image_mini_width"
                android:layout_height="@dimen/size_image_mini_height"
                android:layout_marginEnd="@dimen/margin_end"
                android:src="@drawable/usuario_fotoperfil_default"
                android:scaleType="centerCrop"
                android:contentDescription="@string/hint_asist_foto"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tvNombreAsistido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_asist_alias"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Fila inferior: botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="@dimen/margin_top_element">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSupervisar"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/md_third"
                android:text="@string/hint_supervisar"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpciones"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/md_third"
                app:icon="@drawable/ic_ajustes"
                android:contentDescription="@string/text_title_opciones"
                android:layout_marginStart="@dimen/margin_start_element"
                android:layout_marginEnd="@dimen/margin_end_element"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:text=""
                android:padding="@dimen/padding_icon_mini"/>

        </LinearLayout>

        <!-- Layout de opciones oculto -->
        <LinearLayout
            android:id="@+id/layoutOpciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_top"
            android:gravity="start"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarPerfilAsist"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="@string/button_perf_editar"
                android:backgroundTint="@color/md_background"
                android:textColor="@color/md_black"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDesvincularAsist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="@string/button_perf_desvincular"
                android:textColor="@color/md_black"
                android:backgroundTint="@color/md_background"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarCuentaAsist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="@string/button_eliminar_cuenta"
                android:textAllCaps="false"
                android:backgroundTint="@color/md_background"
                android:textColor="@color/md_error" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
