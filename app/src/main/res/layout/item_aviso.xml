<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/tools"
    android:layout_marginBottom="8dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Contenedor icono + título -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Card del icono -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardIconoAviso"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_surface">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgIconoAviso"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="icono medicamento"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Título -->
            <TextView
                android:id="@+id/tvTituloAviso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Título del aviso"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/md_primary_dark"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMensajeAviso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mensaje opcional"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/md_primary_dark"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIgnorar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ignorar"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/md_primary_dark"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResolver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolver"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/white"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>