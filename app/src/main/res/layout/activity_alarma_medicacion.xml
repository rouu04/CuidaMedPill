<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- Título -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hora de tu medicación"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="24dp"/>

    <!-- Medicamento -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/size_image_icon_card_width"
            android:layout_height="@dimen/size_image_icon_card_height"
            app:cardCornerRadius="@dimen/card_cornerradious"
            app:cardElevation="@dimen/card_elevation"
            app:contentPadding="@dimen/card_contentPadding"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/md_surface">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgMedicamentoAlarma"
                android:layout_width="@dimen/size_image_icon_width"
                android:layout_height="@dimen/size_image_icon_height"
                android:layout_gravity="center"
                android:contentDescription="@string/contdesc_med_simb"/>
        </com.google.android.material.card.MaterialCardView>



        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/txtMedicamento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paracetamol"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/txtFechaProgramadaAlarma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy a las 22:00"
                android:textSize="18sp"
                android:textColor="#666666"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Espacio -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"/>


    <!-- Botones -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTomado"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Tomado"
        android:textSize="18sp"
        android:backgroundTint="@color/md_primary"
        style="@style/Widget.MaterialComponents.Button"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVoyAhora"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Voy a tomarlo ahora"
        android:textSize="18sp"
        android:backgroundTint="@color/md_blue"
        style="@style/Widget.MaterialComponents.Button"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNoTomado"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Ignorar"
        android:textSize="18sp"
        android:backgroundTint="@color/md_error"
        style="@style/Widget.MaterialComponents.Button"
        android:textColor="#FFFFFF"/>

</LinearLayout>