<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/padding_general"
    android:background="?android:attr/windowBackground">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTimer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="@dimen/card_cornerradious"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.15">
        <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/circularTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorSize="280dp"
            app:trackThickness="@dimen/padding_general_light"
            app:indicatorColor="@color/md_primary"
            app:trackColor="#F5F5F5"
            app:trackCornerRadius="@dimen/card_cornerradious"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:max="180"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/circularTimer"
            app:layout_constraintBottom_toBottomOf="@id/circularTimer"
            app:layout_constraintStart_toStartOf="@id/circularTimer"
            app:layout_constraintEnd_toEndOf="@id/circularTimer">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgMedicamentoAntiproc"
                android:layout_width="@dimen/size_image_mini_width"
                android:layout_height="@dimen/size_image_mini_height"/>

            <TextView
                android:id="@+id/txtTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline5"
                android:textColor="@color/md_primary"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutAntiproc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="@dimen/margin_top_element"
        app:layout_constraintTop_toBottomOf="@id/cardTimer"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
        android:id="@+id/txtNombreMedAntiproc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline4"
        android:textColor="?android:attr/textColorPrimary"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmar"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_size_alarm"
        android:text="@string/ya_tomado_formal"
        app:layout_constraintBottom_toTopOf="@id/btnIgnorar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        android:layout_marginBottom="@dimen/margin_bottom_element"
        style="@style/Widget.MaterialComponents.Button"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIgnorar"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_size_alarm"
        android:text="@string/ignorar"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        android:layout_marginBottom="@dimen/margin_bottom_element"/>

</androidx.constraintlayout.widget.ConstraintLayout>