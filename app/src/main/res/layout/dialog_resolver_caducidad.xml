<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="@dimen/padding_general">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTipoMedDet"
            android:layout_width="@dimen/size_image_icon_card_width"
            android:layout_height="@dimen/size_image_icon_card_height"
            app:cardCornerRadius="@dimen/card_cornerradious"
            app:cardElevation="@dimen/card_elevation"
            app:contentPadding="@dimen/card_contentPadding"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/md_surface">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgTipoMedCad"
                android:layout_width="@dimen/size_image_icon_width"
                android:layout_height="@dimen/size_image_icon_height"
                android:layout_gravity="center"
                android:contentDescription="@string/contdesc_med_simb"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvNombreMedCad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_med_nombremed"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvPreguntaCaducidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_title_fecha_caducidad"
        android:layout_marginTop="@dimen/margin_top_element"/>


    <!-- Bloque fecha cad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="@dimen/margin_top_element">

        <!-- informativo -->
        <TextView
            android:id="@+id/tvLabelFechaCad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_med_fecha_caducidad"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

        <TextView
            android:id="@+id/tvFechaCadCad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/text_title_sinfechasel"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:layout_marginTop="@dimen/margin_mini"/>
    </LinearLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/margin_top_element">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuitarFechaCad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/text_title_quitarfecha"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_marginEnd="@dimen/margin_top_element"
            android:layout_marginTop="@dimen/margin_top_element"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionarFechaCad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/text_title_selfecha"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_marginTop="@dimen/margin_top_element"/>
    </LinearLayout>

</LinearLayout>