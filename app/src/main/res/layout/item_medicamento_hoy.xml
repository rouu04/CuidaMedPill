<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_elem"
    app:cardCornerRadius="@dimen/card_cornerradious"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/md_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/padding_mini">

        <!-- Contenido izquierdo (ocupa espacio) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Fila superior: imagen + nombre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgTipoMedHoy"
                    android:layout_width="@dimen/size_image_mini_width"
                    android:layout_height="@dimen/size_image_mini_height"
                    android:contentDescription="@string/contdesc_med_simb"
                    android:layout_marginEnd="@dimen/margin_mini"/>

                <TextView
                    android:id="@+id/tvNombreMedHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/md_primary_dark"/>
            </LinearLayout>

            <!-- Fila inferior: hora + botón -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/margin_top_element"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_top"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                    android:textColor="@color/md_primary_dark"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_size_icon"
                    android:backgroundTint="@null"
                    app:icon="@drawable/ic_tick"
                    app:iconSize="@dimen/size_image_icon_mini_width"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    app:iconPadding="0dp"/>
            </LinearLayout>

        </LinearLayout>
f    </LinearLayout>

</com.google.android.material.card.MaterialCardView>