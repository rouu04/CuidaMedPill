<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/padding_general">

    <!-- Icono + Nombre del medicamento -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTipoMedDet"
            android:layout_width="@dimen/size_image_icon_card_width"
            android:layout_height="@dimen/size_image_icon_card_height"
            app:cardCornerRadius="@dimen/card_cornerradious"
            app:cardElevation="@dimen/card_elevation"
            app:contentPadding="@dimen/card_contentPadding"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/md_surface">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgTipoMed"
                android:layout_width="@dimen/size_image_icon_width"
                android:layout_height="@dimen/size_image_icon_height"
                android:layout_gravity="center"
                android:contentDescription="@string/contdesc_med_simb"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvNombreMed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_med_nombremed"
            android:textStyle="bold"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            android:layout_marginStart="@dimen/margin_start_element"/>
    </LinearLayout>

    <!-- Pregunta sobre fin de tratamiento -->
    <TextView
        android:id="@+id/tvPreguntaFinTratamiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_title_tratamiento_terminado"
        android:layout_marginTop="@dimen/margin_top_element"/>

    <!-- Fecha seleccionada / actual -->
    <TextView
        android:id="@+id/tvFechaFinTrat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_title_sinfechasel"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/margin_top_element"/>

    <!-- Botón para seleccionar fecha -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSeleccionarFechaFin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_title_selfecha"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="@dimen/margin_top_element"/>

    <!-- Botón para quitar fecha -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuitarFechaFin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_title_quitarfecha"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="@dimen/margin_top_element"/>

</LinearLayout>