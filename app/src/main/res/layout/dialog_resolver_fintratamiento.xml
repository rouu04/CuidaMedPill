<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Icono + Nombre del medicamento -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTipoMedDet"
            android:layout_width="@dimen/size_image_icon_card_width"
            android:layout_height="@dimen/size_image_icon_card_height"
            app:cardCornerRadius="@dimen/card_cornerradious"
            app:cardElevation="@dimen/card_elevation"
            app:contentPadding="@dimen/card_contentPadding"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/md_surface">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgTipoMed"
                android:layout_width="@dimen/size_image_icon_width"
                android:layout_height="@dimen/size_image_icon_height"
                android:layout_gravity="center"
                android:contentDescription="@string/contdesc_med_simb"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvNombreMed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre medicamento"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Pregunta sobre fin de tratamiento -->
    <TextView
        android:id="@+id/tvPreguntaFinTratamiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿El tratamiento ha terminado?"
        android:layout_marginTop="16dp"/>

    <!-- Fecha seleccionada / actual -->
    <TextView
        android:id="@+id/tvFechaFinTrat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sin fecha seleccionada"
        android:textStyle="bold"
        android:layout_marginTop="12dp"/>

    <!-- Botón para seleccionar fecha -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSeleccionarFechaFin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar fecha"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="8dp"/>

    <!-- Botón para quitar fecha -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuitarFechaFin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quitar fecha"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="8dp"/>

</LinearLayout>